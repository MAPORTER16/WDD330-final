{
    "env": {
        "browser": true,
        "es2021": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": "warn",
        "no-undef": "error",
        "semi": [
            "warn",
            "always"
        ],
        "no-console": "off",
        "eqeqeq": "error",
        "no-var": "error",
        "prefer-const": "warn"
    }
}